# ============================================================
# E-Incarnation Frontend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# Backend API base URL
# Production (Render): https://e-incarnation-recycling-pvt-ltd-backend.onrender.com/api
# Local development:   http://localhost:5001/api
VITE_API_URL=https://e-incarnation-recycling-pvt-ltd-backend.onrender.com/api

# Google reCAPTCHA v2 Site Key (public key — safe to expose in frontend)
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here

# Canonical site URL used in SEO meta tags and structured data
VITE_SITE_URL=https://www.e-incarnation.com
